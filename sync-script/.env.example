# ─── MySQL (PC del chip timing) ───────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=tu_password
MYSQL_DB=nombre_base_de_datos
MYSQL_TABLE=cicloturista
# Alternativa recomendada: varias tablas separadas por coma
# MYSQL_TABLES=cicloturista,cicloturistag,especial,parejas,parejasG

# ─── API backend propio (sin Supabase) ───────────────────
# mysql (por defecto), csv o csv-url
RESULTS_SOURCE=mysql
API_PORT=8787
API_KEY=pon_una_clave_larga_y_privada
# Si RESULTS_SOURCE=csv, define ruta absoluta o relativa al script
# CSV_FILE=./resultados.csv
# Si RESULTS_SOURCE=csv-url, define una URL pública al CSV
# CSV_URL=https://raw.githubusercontent.com/usuario/repositorio/main/resultados.csv
# CSV_SOURCE_TABLE=CSV

# ─── Supabase ─────────────────────────────────────────────
# Obtenlos en: https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...  # usa la SERVICE ROLE key (no la anon)
